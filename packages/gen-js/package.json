{
  "name": "@rdf-shuttle/gen-js",
  "version": "0.1.0",
  "description": "Shuttle JS backend: emits a dependency-free streaming parser + serializer module from a .shuttle grammar",
  "type": "module",
  "license": "MIT",
  "bin": {
    "shuttle-gen-js": "src/cli.js"
  },
  "exports": {
    ".": "./src/generate.js",
    "./turtle12": "./generated/turtle12.js"
  },
  "scripts": {
    "generate": "node src/cli.js ../../grammars/turtle12.shuttle -o generated/turtle12.js",
    "test": "npm run generate && node --test test/"
  }
}

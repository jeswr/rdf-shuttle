@base <http://example.org/leak> .
@prefix ex: <http://example.org/test#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

<> a owl:Ontology .

ex:TestShape a sh:NodeShape ;
	sh:property [
		sh:path ex:property ;
		sh:class ex:TestClass ;
		ex:myPropertyEscape 1
	] .
